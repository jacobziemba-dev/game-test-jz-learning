+  _updateCrafting(dt) {
+    if (!this.craftTarget || this.craftQuantity <= 0) {
+      this.state = PlayerState.IDLE;
+      this.craftTarget = null;
+      return;
+    }
+
+    this.craftTimer += dt;
+
+    if (this.craftTimer >= this.craftInterval) {
+      this.craftTimer = 0;
+
+      const { recipe, station } = this.craftTarget;
+      const result = recipe.executeBatch(this.inventory, this.skills, { times: 1, station });
+
+      if (result.attempted <= 0) {
+        // Requirements not met, stop crafting
+        this.state = PlayerState.IDLE;
+        this.craftTarget = null;
+      } else {
+        this.craftQuantity--;
+        const itemName = recipe.name;
+        this.addFloatingText(result.crafted > 0 ? `+1 ${itemName}` : `Failed`, result.crafted > 0 ? '#81c784' : '#ffcc80');
+      }
+    }
+  }
