# OS
.DS_Store
._*
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.iml
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Dependencies & build output (if you add Node/npm later)
node_modules/
dist/
build/
out/
coverage/
.nyc_output/
.cache/
.parcel-cache/
.vite/
.sass-cache/

# Environment & secrets
.env
.env.*
!.env.example
local.settings.json

# Temporary / backup
*.tmp
*.temp
*.bak
*.local
*.orig
*.rej

# Linters & TypeScript (if you add them)
.eslintcache
*.tsbuildinfo

# Local IDE / editor history (e.g. Local History extension)
.history/

# Patches & archives
*.diff
patch_*.diff
*.zip
*.tar.gz
*.tar
*.rar

# Legacy JS package managers (rare today)
bower_components/
jspm_packages/

# Optional: local exports / dumps (don’t ignore repo images — you need sprites!)
screenshots/
assets/exports/
exported-assets/

# Deploy CLIs (local link / build cache — keep netlify.toml, vercel.json, etc. tracked)
.vercel/
.netlify/

# E2E (only matters if you add Playwright / Cypress)
playwright-report/
test-results/
blob-report/
playwright/.cache/
cypress/videos/
cypress/screenshots/
